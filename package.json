{
  "name": "yutong-browser",
  "productName": "钰彤指纹浏览器",
  "version": "2.1.3",
  "description": "Multi-instance anti-association browser for WhatsApp CRM",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder -w"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "socks-proxy-agent": "^10.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yutong.browser",
    "productName": "钰彤指纹浏览器",
    "publish": [
      {
        "provider": "github",
        "owner": "Gustavo-Yi",
        "repo": "browser"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "钰彤指纹浏览器"
    }
  }
}
